# This web layer has no external authentication. Every request resolves to
# a single fixed local user with admin rights (see backend/auth.py). There
# is no access control — do not expose a deployment publicly.
#
# No environment variables are required to run it. The settings below are
# optional overrides.

# ─── Pipeline data ───────────────────────────────────────────────────────
# Defaults resolve to ../runner relative to the OntologyMapper repo root.
# Override only when running the runner from a different location.

# RUNS_DIR=/path/to/OntologyMapper/runner/.mapper-runs
# RUNNER_DIR=/path/to/OntologyMapper/runner

# ─── Backend ─────────────────────────────────────────────────────────────

# BACKEND_PORT=8000
