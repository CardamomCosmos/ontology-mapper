### Violation scenario with appeal
dbpi:ComplaintDocument_204 a dbpi:Document ;
    dbpi:documentNumber "CMP-2026-0204" ;
    dbpi:displayName "Complaint regarding unpermitted garage conversion at 77 Juniper Lane" ;
    dbpi:documentDate "2026-03-14"^^xsd:date .

dbpi:Notice_7819 a dbpi:NoticeOfViolation ;
    dbpi:documentNumber "NOV-7819" ;
    dbpi:displayName "Notice of Violation NOV-7819" ;
    dbpi:documentDate "2026-03-18"^^xsd:date ;
    dbpi:citesCodeSection dbpi:CodeSection_HAB_12_4 ;
    dbpi:description "Occupancy and egress deficiencies identified in unpermitted garage conversion." .

dbpi:CodeSection_HAB_12_4 a dbpi:CodeSection ;
    dbpi:identifier "HAB-12.4" ;
    dbpi:displayName "Habitable rooms and emergency egress requirements" .

dbpi:Inspection_7819 a dbpi:Inspection ;
    dbpi:inspectionNumber "INSP-2026-07819" ;
    dbpi:inspectionType dcp:InspectionFinal ;
    dbpi:hasInspectionStatus dcp:InspectionCompleted ;
    dbpi:hasInspectionResult dcp:InspectionFail ;
    dbpi:scheduledFor "2026-03-17T13:30:00"^^xsd:dateTime ;
    dbpi:completedAt "2026-03-17T14:05:00"^^xsd:dateTime ;
    dbpi:performedBy dbpi:AliceNguyen ;
    dbpi:inspectedProperty dbpi:Property_77Juniper ;
    dbpi:note "Observed converted garage occupied without permit and without code-compliant egress." ;
    dbpi:citesCodeSection dbpi:CodeSection_HAB_12_4 .

dbpi:CorrectiveAction_7819_1 a dbpi:CorrectiveAction ;
    dbpi:identifier "CA-7819-1" ;
    dbpi:description "Cease occupancy of the converted space and submit legalization or restoration plan." ;
    dbpi:dueDate "2026-04-02"^^xsd:date .

dbpi:ViolationCase_7819 a dbpi:ViolationCase ;
    dbpi:violationCaseNumber "CASE-2026-7819" ;
    dbpi:openedDate "2026-03-17"^^xsd:date ;
    dbpi:relatedInspection dbpi:Inspection_7819 ;
    dbpi:relatedProperty dbpi:Property_77Juniper ;
    dbpi:hasCaseStatus dcp:CaseReferred ;
    dbpi:hasNotice dbpi:Notice_7819 ;
    dbpi:hasCorrectiveAction dbpi:CorrectiveAction_7819_1 ;
    dbpi:assignedToUnit dbpi:EnforcementDivision ;
    dbpi:assignedToEmployee dbpi:HelenaCho ;
    dbpi:description "Garage conversion case escalated to administrative hearing after missed compliance deadline." ;
    dbpi:hasSupportingDocument dbpi:ComplaintDocument_204 .

dbpi:Appeal_7819 a dbpi:Appeal ;
    dbpi:identifier "APL-2026-7819" ;
    dbpi:forCase dbpi:ViolationCase_7819 ;
    dbpi:submittedBy dbpi:JuniperHomesLLC ;
    dbpi:submittedDate "2026-03-22"^^xsd:date ;
    dbpi:hasAppealStatus dcp:AppealDenied ;
    dbpi:description "Owner appealed notice on hardship grounds; original action sustained." .

dbpi:Hearing_7819 a dbpi:Hearing ;
    dbpi:identifier "HRG-2026-7819" ;
    dbpi:forCase dbpi:ViolationCase_7819 ;
    dbpi:heardBy dbpi:RosaMartinez ;
    dbpi:hearingDate "2026-04-11T09:00:00"^^xsd:dateTime ;
    dbpi:description "Administrative hearing on unpermitted occupancy and habitability deficiencies." .

dbpi:ViolationCase_7819 dbpi:hasAppeal dbpi:Appeal_7819 .

