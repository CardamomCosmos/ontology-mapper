@prefix dbpi: <https://data.redvale.gov/ontology/dbpi/> .
@prefix dcp: <https://data.redvale.gov/ontology/dbpi/codelists#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dbpi:AppealLifecycle a dbpi:WorkflowModel ;
    dbpi:appliesAuthorityId "AUTH-DBPI-005",
        "AUTH-DBPI-009" ;
    dbpi:appliesToClass dbpi:Appeal ;
    dbpi:displayName "Appeal Lifecycle" ;
    dbpi:hasWorkflowState dbpi:WFS_Appeal_Denied,
        dbpi:WFS_Appeal_Granted,
        dbpi:WFS_Appeal_Pending ;
    dbpi:hasWorkflowTransition dbpi:WFT_Appeal_1,
        dbpi:WFT_Appeal_2 .

dbpi:Hearing_7782 a dbpi:Hearing ;
    dbpi:description "Administrative hearing on appeal APL-7782." ;
    dbpi:forCase dbpi:ViolationCase_7782 ;
    dbpi:heardBy dbpi:RosaMartinez ;
    dbpi:hearingDate "2026-03-15T13:30:00"^^xsd:dateTime ;
    dbpi:identifier "HEAR-7782" .

dbpi:Hearing_7819 a dbpi:Hearing ;
    dbpi:description "Administrative hearing on unpermitted occupancy and habitability deficiencies." ;
    dbpi:forCase dbpi:ViolationCase_7819 ;
    dbpi:heardBy dbpi:RosaMartinez ;
    dbpi:hearingDate "2026-04-11T09:00:00"^^xsd:dateTime ;
    dbpi:identifier "HRG-2026-7819" .

dbpi:InspectionRequestLifecycle a dbpi:WorkflowModel ;
    dbpi:appliesAuthorityId "AUTH-DBPI-003",
        "AUTH-DBPI-014" ;
    dbpi:appliesToClass dbpi:InspectionRequest ;
    dbpi:displayName "Inspection Request Lifecycle" ;
    dbpi:hasWorkflowState dbpi:WFS_InspReq_Canceled,
        dbpi:WFS_InspReq_Completed,
        dbpi:WFS_InspReq_Requested,
        dbpi:WFS_InspReq_Scheduled ;
    dbpi:hasWorkflowTransition dbpi:WFT_InspReq_1,
        dbpi:WFT_InspReq_2,
        dbpi:WFT_InspReq_3,
        dbpi:WFT_InspReq_4 .

dbpi:InspectionShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:inspectionNumber ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:inspectionType ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:hasInspectionResult ],
        [ sh:class dbpi:Property ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:inspectedProperty ],
        [ sh:class dbpi:Inspector ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:performedBy ],
        [ sh:class dbpi:Permit ;
            sh:maxCount 1 ;
            sh:path dbpi:forPermit ] ;
    sh:targetClass dbpi:Inspection .

dbpi:Inspection_612 a dbpi:Inspection ;
    dbpi:completedAt "2026-03-12T10:18:00"^^xsd:dateTime ;
    dbpi:forPermit dbpi:Permit_0064 ;
    dbpi:fulfillsRequest dbpi:InspectionRequest_612 ;
    dbpi:hasInspectionResult dcp:InspectionPass ;
    dbpi:hasInspectionStatus dcp:InspectionCompleted ;
    dbpi:inspectedProperty dbpi:Property_18Harbor ;
    dbpi:inspectionNumber "INSP-2026-0612" ;
    dbpi:inspectionType dcp:InspectionFinal ;
    dbpi:note "Service panel upgrade completed in conformity with approved plans." ;
    dbpi:performedBy dbpi:AliceNguyen ;
    dbpi:scheduledFor "2026-03-12T10:00:00"^^xsd:dateTime .

dbpi:MarcoSilva a dbpi:PermitTechnician ;
    dbpi:displayName "Marco Silva" ;
    dbpi:email "marco.silva@redvale.gov" ;
    dbpi:employeeNumber "E1015" ;
    dbpi:hasRole dbpi:Role_PermitTechnician ;
    dbpi:memberOf dbpi:PermitServicesDivision .

dbpi:PermitApplicationLifecycle a dbpi:WorkflowModel ;
    dbpi:appliesAuthorityId "AUTH-DBPI-002",
        "AUTH-DBPI-012" ;
    dbpi:appliesToClass dbpi:PermitApplication ;
    dbpi:displayName "Permit Application Lifecycle" ;
    dbpi:hasWorkflowState dbpi:WFS_App_Approved,
        dbpi:WFS_App_Denied,
        dbpi:WFS_App_Received,
        dbpi:WFS_App_UnderReview,
        dbpi:WFS_App_Withdrawn ;
    dbpi:hasWorkflowTransition dbpi:WFT_App_1,
        dbpi:WFT_App_2,
        dbpi:WFT_App_3,
        dbpi:WFT_App_4,
        dbpi:WFT_App_5 .

dbpi:PermitApplicationShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:requestedWorkType ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:hasApplicationStatus ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:applicationNumber ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:submittedDate ],
        [ sh:class dbpi:Agent ;
            sh:minCount 1 ;
            sh:path dbpi:submittedBy ],
        [ sh:class dbpi:Property ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:concernsProperty ],
        [ sh:class dbpi:PublicService ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:forService ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:requestedPermitType ] ;
    sh:targetClass dbpi:PermitApplication .

dbpi:PermitLifecycle a dbpi:WorkflowModel ;
    dbpi:appliesAuthorityId "AUTH-DBPI-002",
        "AUTH-DBPI-004" ;
    dbpi:appliesToClass dbpi:Permit ;
    dbpi:displayName "Permit Lifecycle" ;
    dbpi:hasWorkflowState dbpi:WFS_Permit_Active,
        dbpi:WFS_Permit_Expired,
        dbpi:WFS_Permit_Finaled,
        dbpi:WFS_Permit_Revoked,
        dbpi:WFS_Permit_Suspended ;
    dbpi:hasWorkflowTransition dbpi:WFT_Permit_1,
        dbpi:WFT_Permit_2,
        dbpi:WFT_Permit_3,
        dbpi:WFT_Permit_4,
        dbpi:WFT_Permit_5,
        dbpi:WFT_Permit_6,
        dbpi:WFT_Permit_7 .

dbpi:PermitShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:permitNumber ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:issuedDate ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:expirationDate ],
        [ sh:class dbpi:PermitApplication ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:basedOnApplication ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:authorizedPermitType ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:authorizedWorkType ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:hasPermitStatus ],
        [ sh:class dbpi:Organization ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:issuedBy ] ;
    sh:targetClass dbpi:Permit .

dbpi:PropertyShape a sh:NodeShape ;
    sh:property [ sh:class dbpi:Parcel ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:hasParcel ],
        [ sh:class dbpi:Jurisdiction ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:locatedInJurisdiction ],
        [ sh:class dbpi:Address ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:hasAddress ] ;
    sh:targetClass dbpi:Property .

dbpi:RecordsRequestDocument_0091 a dbpi:Document ;
    dbpi:assignedToEmployee dbpi:SamuelReed ;
    dbpi:assignedToUnit dbpi:RecordsUnit ;
    dbpi:concernsProperty dbpi:Property_500Market ;
    dbpi:description "Requester sought issued permits, inspection outcomes, and violation notices for the property." ;
    dbpi:displayName "Public records request for permit history of 500 Market Street" ;
    dbpi:documentDate "2026-03-09"^^xsd:date ;
    dbpi:documentNumber "PRR-2026-0091" ;
    dbpi:forService dbpi:PublicRecordsService ;
    dbpi:submittedBy dbpi:Citizen_MaryCole .

dbpi:RecordsRequestLifecycle a dbpi:WorkflowModel ;
    dbpi:appliesAuthorityId "AUTH-DBPI-010",
        "AUTH-DBPI-016" ;
    dbpi:appliesToClass dbpi:Document ;
    dbpi:displayName "Records Request Lifecycle" ;
    dbpi:hasWorkflowState dbpi:WFS_RecReq_Closed,
        dbpi:WFS_RecReq_Denied,
        dbpi:WFS_RecReq_Fulfilled,
        dbpi:WFS_RecReq_InReview,
        dbpi:WFS_RecReq_PartiallyFulfilled,
        dbpi:WFS_RecReq_Received ;
    dbpi:hasWorkflowTransition dbpi:WFT_RecReq_1,
        dbpi:WFT_RecReq_2,
        dbpi:WFT_RecReq_3,
        dbpi:WFT_RecReq_4,
        dbpi:WFT_RecReq_5,
        dbpi:WFT_RecReq_6,
        dbpi:WFT_RecReq_7 .

dbpi:RecordsResponseDocument_0091 a dbpi:Document ;
    dbpi:description "Released permit history, final inspection records, and notice log with one personal-contact redaction." ;
    dbpi:displayName "Responsive records package for PRR-2026-0091" ;
    dbpi:documentDate "2026-03-13"^^xsd:date ;
    dbpi:documentNumber "PRR-2026-0091-RESP" ;
    dbpi:forService dbpi:PublicRecordsService .

dbpi:ViolationCaseLifecycle a dbpi:WorkflowModel ;
    dbpi:appliesAuthorityId "AUTH-DBPI-004",
        "AUTH-DBPI-015" ;
    dbpi:appliesToClass dbpi:ViolationCase ;
    dbpi:displayName "Violation Case Lifecycle" ;
    dbpi:hasWorkflowState dbpi:WFS_Case_Closed,
        dbpi:WFS_Case_Open,
        dbpi:WFS_Case_PendingCompliance,
        dbpi:WFS_Case_Referred ;
    dbpi:hasWorkflowTransition dbpi:WFT_Case_1,
        dbpi:WFT_Case_2,
        dbpi:WFT_Case_3,
        dbpi:WFT_Case_4,
        dbpi:WFT_Case_5 .

dbpi:ViolationCaseShape a sh:NodeShape ;
    sh:or ( [ sh:property [ sh:class dbpi:Inspection ;
                        sh:minCount 1 ;
                        sh:path dbpi:relatedInspection ] ] [ sh:property [ sh:class dbpi:Permit ;
                        sh:minCount 1 ;
                        sh:path dbpi:relatedPermit ] ] ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:violationCaseNumber ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:openedDate ],
        [ sh:class dbpi:Property ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:relatedProperty ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path dbpi:hasCaseStatus ] ;
    sh:targetClass dbpi:ViolationCase .

dbpi:all a owl:Ontology ;
    rdfs:label "DBPI Combined Ontology" ;
    rdfs:comment "Import ontology that gathers the DBPI modules." ;
    owl:imports dbpi:core,
        dbpi:enforcement,
        dbpi:inspections,
        dbpi:organization,
        dbpi:permitting,
        dbpi:workflows .

