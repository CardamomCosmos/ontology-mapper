dbpi:WFT_App_1 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_App_Received ;
    dbpi:toState dbpi:WFS_App_UnderReview ;
    dbpi:transitionTrigger "Intake completeness confirmed and routing initiated." .

dbpi:WFT_App_2 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_App_UnderReview ;
    dbpi:toState dbpi:WFS_App_Approved ;
    dbpi:transitionTrigger "All required reviews approved and issuance prerequisites satisfied." .

dbpi:WFT_App_3 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_App_UnderReview ;
    dbpi:toState dbpi:WFS_App_Denied ;
    dbpi:transitionTrigger "Substantive noncompliance results in denial." .

dbpi:WFT_App_4 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_App_UnderReview ;
    dbpi:toState dbpi:WFS_App_Withdrawn ;
    dbpi:transitionTrigger "Applicant withdraws the application during review." .

dbpi:WFT_App_5 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_App_Received ;
    dbpi:toState dbpi:WFS_App_Withdrawn ;
    dbpi:transitionTrigger "Applicant withdraws before review begins." .

dbpi:WFT_Appeal_1 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Appeal_Pending ;
    dbpi:toState dbpi:WFS_Appeal_Granted ;
    dbpi:transitionTrigger "Hearing or review results in modified or reversed action." .

dbpi:WFT_Appeal_2 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Appeal_Pending ;
    dbpi:toState dbpi:WFS_Appeal_Denied ;
    dbpi:transitionTrigger "Original action sustained after review." .

dbpi:WFT_Case_1 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Case_Open ;
    dbpi:toState dbpi:WFS_Case_PendingCompliance ;
    dbpi:transitionTrigger "Violation confirmed and corrective action issued." .

dbpi:WFT_Case_2 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Case_Open ;
    dbpi:toState dbpi:WFS_Case_Closed ;
    dbpi:transitionTrigger "Complaint unsubstantiated or outside jurisdiction." .

dbpi:WFT_Case_3 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Case_PendingCompliance ;
    dbpi:toState dbpi:WFS_Case_Closed ;
    dbpi:transitionTrigger "Compliance verified." .

dbpi:WFT_Case_4 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Case_PendingCompliance ;
    dbpi:toState dbpi:WFS_Case_Referred ;
    dbpi:transitionTrigger "Noncompliance persists and matter is escalated." .

dbpi:WFT_Case_5 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Case_Referred ;
    dbpi:toState dbpi:WFS_Case_Closed ;
    dbpi:transitionTrigger "Referred matter reaches final disposition." .

dbpi:WFT_InspReq_1 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_InspReq_Requested ;
    dbpi:toState dbpi:WFS_InspReq_Scheduled ;
    dbpi:transitionTrigger "Appointment slot assigned." .

dbpi:WFT_InspReq_2 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_InspReq_Requested ;
    dbpi:toState dbpi:WFS_InspReq_Canceled ;
    dbpi:transitionTrigger "Request canceled before scheduling." .

dbpi:WFT_InspReq_3 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_InspReq_Scheduled ;
    dbpi:toState dbpi:WFS_InspReq_Completed ;
    dbpi:transitionTrigger "Inspection performed and request fulfilled." .

dbpi:WFT_InspReq_4 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_InspReq_Scheduled ;
    dbpi:toState dbpi:WFS_InspReq_Canceled ;
    dbpi:transitionTrigger "Appointment canceled." .

dbpi:WFT_Permit_1 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Active ;
    dbpi:toState dbpi:WFS_Permit_Suspended ;
    dbpi:transitionTrigger "Active work is placed on hold pending correction or administrative action." .

dbpi:WFT_Permit_2 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Suspended ;
    dbpi:toState dbpi:WFS_Permit_Active ;
    dbpi:transitionTrigger "Suspension basis cured and permit reinstated." .

dbpi:WFT_Permit_3 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Active ;
    dbpi:toState dbpi:WFS_Permit_Expired ;
    dbpi:transitionTrigger "Permit lapses by time or inactivity." .

dbpi:WFT_Permit_4 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Active ;
    dbpi:toState dbpi:WFS_Permit_Finaled ;
    dbpi:transitionTrigger "All required final approvals completed." .

dbpi:WFT_Permit_5 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Active ;
    dbpi:toState dbpi:WFS_Permit_Revoked ;
    dbpi:transitionTrigger "Permit is revoked for authorized cause." .

dbpi:WFT_Permit_6 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Suspended ;
    dbpi:toState dbpi:WFS_Permit_Revoked ;
    dbpi:transitionTrigger "Suspended permit proceeds to revocation." .

dbpi:WFT_Permit_7 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_Permit_Suspended ;
    dbpi:toState dbpi:WFS_Permit_Expired ;
    dbpi:transitionTrigger "Suspended permit lapses before reinstatement." .

dbpi:WFT_RecReq_1 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_Received ;
    dbpi:toState dbpi:WFS_RecReq_InReview ;
    dbpi:transitionTrigger "Request sufficiently specific and accepted for processing." .

dbpi:WFT_RecReq_2 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_InReview ;
    dbpi:toState dbpi:WFS_RecReq_Fulfilled ;
    dbpi:transitionTrigger "Records located and released in full." .

dbpi:WFT_RecReq_3 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_InReview ;
    dbpi:toState dbpi:WFS_RecReq_PartiallyFulfilled ;
    dbpi:transitionTrigger "Records released with lawful redactions or partial withholding." .

dbpi:WFT_RecReq_4 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_InReview ;
    dbpi:toState dbpi:WFS_RecReq_Denied ;
    dbpi:transitionTrigger "Exemption applies or unable to locate responsive records." .

dbpi:WFT_RecReq_5 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_Fulfilled ;
    dbpi:toState dbpi:WFS_RecReq_Closed ;
    dbpi:transitionTrigger "Administrative completion." .

dbpi:WFT_RecReq_6 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_PartiallyFulfilled ;
    dbpi:toState dbpi:WFS_RecReq_Closed ;
    dbpi:transitionTrigger "Administrative completion." .

dbpi:WFT_RecReq_7 a dbpi:WorkflowTransition ;
    dbpi:fromState dbpi:WFS_RecReq_Denied ;
    dbpi:toState dbpi:WFS_RecReq_Closed ;
    dbpi:transitionTrigger "Administrative completion." .

