dcp:PermitTypeElectrical a skos:Concept ; skos:inScheme dcp:PermitTypeScheme ; skos:prefLabel "Electrical" .
dcp:PermitTypeMechanical a skos:Concept ; skos:inScheme dcp:PermitTypeScheme ; skos:prefLabel "Mechanical" .
dcp:PermitTypeDemolition a skos:Concept ; skos:inScheme dcp:PermitTypeScheme ; skos:prefLabel "Demolition" .

dcp:WorkTypeScheme a skos:ConceptScheme ; skos:prefLabel "Work Type Scheme" .
dcp:WorkInteriorRenovation a skos:Concept ; skos:inScheme dcp:WorkTypeScheme ; skos:prefLabel "Interior Renovation" .
