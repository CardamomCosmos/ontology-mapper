@prefix dbpi: <https://data.redvale.gov/ontology/dbpi/> .
@prefix dcp: <https://data.redvale.gov/ontology/dbpi/codelists#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://data.redvale.gov/ontology/dbpi/codelists> a owl:Ontology ;
    rdfs:label "DBPI Controlled Vocabularies" ;
    rdfs:comment "SKOS concept schemes for statuses and classifications used by DBPI." .

dcp:ApplicationStatusScheme a skos:ConceptScheme ; skos:prefLabel "Application Status Scheme" .
dcp:StatusReceived a skos:Concept ; skos:inScheme dcp:ApplicationStatusScheme ; skos:prefLabel "Received" .
dcp:StatusUnderReview a skos:Concept ; skos:inScheme dcp:ApplicationStatusScheme ; skos:prefLabel "Under Review" .
dcp:StatusApproved a skos:Concept ; skos:inScheme dcp:ApplicationStatusScheme ; skos:prefLabel "Approved" .
